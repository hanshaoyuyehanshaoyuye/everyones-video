{
  "manifest_version": 3,
  "name": "Everyones Video — 实时双语字幕",
  "version": "1.0.0",
  "description": "YouTube 实时翻译字幕。劫持自带字幕→TM缓存→LLM翻译→双语叠加。完全免费，MIT开源。",
  "permissions": ["storage"],
  "host_permissions": [
    "https://*/*",
    "http://127.0.0.1:8739/*",
    "http://localhost:8739/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content.js"],
      "css": ["overlay.css"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "实时双语字幕",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["overlay.css"],
      "matches": ["https://www.youtube.com/*"]
    }
  ]
}
